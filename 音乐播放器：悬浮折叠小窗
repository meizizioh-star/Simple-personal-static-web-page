  <!-- ====== 音乐播放器：悬浮小窗 ====== -->
<div id="music-player">
  <button id="mp-toggle" title="展开/收起">🎵</button>

  <div id="mp-panel">
    <div class="mp-row">
      <div class="mp-title" id="mp-title">BGM</div>
      <button id="mp-close" title="收起">✖</button>
    </div>

    <div class="mp-row mp-controls">
      <button id="mp-play">▶</button>
      <button id="mp-pause">⏸</button>

      <input id="mp-progress" type="range" min="0" max="100" value="0" />
      <span id="mp-time">00:00 / 00:00</span>
    </div>

    <div class="mp-row mp-controls">
      <span>🔊</span>
      <input id="mp-volume" type="range" min="0" max="1" step="0.01" value="0.6" />
      <button id="mp-next" title="下一首">⏭</button>
    </div>
  </div>

  <!-- 真正播放用的 audio -->
  <audio id="bgm" preload="auto"></audio>
</div>

<style>
  #music-player{
  position: fixed;
  top: 14px;                 /* 距离顶部 */
  left: 50%;                 /* 水平居中 */
  transform: translateX(-50%);
  z-index: 99999;            /* 比背景视频高 */
  font-family: inherit;
  pointer-events: auto;
}
  #mp-toggle{
    width: 46px;
    height: 46px;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,.35);
    background: rgba(0,0,0,.35);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #fff;
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(0,0,0,.25);
  }
  #mp-panel{
    margin-top: 10px;
    width: 320px;
    padding: 12px 12px 10px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,.25);
    background: rgba(0,0,0,.35);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #fff;
    box-shadow: 0 10px 30px rgba(0,0,0,.25);
    display: none;
  }
  #mp-panel.show{ display:block; }

  .mp-row{
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom: 10px;
  }
  .mp-title{
    flex:1;
    font-size: 14px;
    opacity: .95;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #mp-close{
    border: none;
    background: transparent;
    color: #fff;
    cursor: pointer;
    opacity: .8;
  }
  .mp-controls button{
    border: 1px solid rgba(255,255,255,.25);
    background: rgba(255,255,255,.12);
    color:#fff;
    border-radius: 12px;
    padding: 6px 10px;
    cursor:pointer;
  }
  .mp-controls input[type="range"]{
    flex:1;
    accent-color: #ffffff;
  }
  #mp-time{
    font-size: 12px;
    opacity: .85;
    width: 98px;
    text-align: right;
  }
</style>

<script>
(() => {
  // 1) 你的歌单：把链接换成你自己的 mp3/ogg
  const playlist = [
    { title: "BGM - 1", url: "https://live2d.honkai.ct8.pl/mc/HOYO-MiX%20-%20Da%20Capo.mp3" },
    { title: "BGM - 2", url: "https://live2d.honkai.ct8.pl/mc/%e8%8c%b6%e7%90%86%e7%90%86%20TetraCalyx%20Hanser%20HOYO-MiX%20-%20Moon%20Halo.mp3" }
  ];

  const playerWrap = document.getElementById("music-player");
  const panel = document.getElementById("mp-panel");
  const toggleBtn = document.getElementById("mp-toggle");
  const closeBtn = document.getElementById("mp-close");

  const audio = document.getElementById("bgm");
  const titleEl = document.getElementById("mp-title");

  const playBtn = document.getElementById("mp-play");
  const pauseBtn = document.getElementById("mp-pause");
  const nextBtn = document.getElementById("mp-next");

  const progress = document.getElementById("mp-progress");
  const timeEl = document.getElementById("mp-time");
  const volume = document.getElementById("mp-volume");

  // 2) 状态记忆
  const LS_KEY = "nezha_bgm_state";
  const state = JSON.parse(localStorage.getItem(LS_KEY) || "{}");
  let index = Number.isInteger(state.index) ? state.index : 0;

  function fmt(sec){
    if (!isFinite(sec)) return "00:00";
    sec = Math.max(0, Math.floor(sec));
    const m = String(Math.floor(sec/60)).padStart(2,"0");
    const s = String(sec%60).padStart(2,"0");
    return `${m}:${s}`;
  }

  function loadSong(i){
    index = (i + playlist.length) % playlist.length;
    const song = playlist[index];
    titleEl.textContent = song.title;
    audio.src = song.url;
    audio.load();

    // 恢复音量
    audio.volume = (typeof state.volume === "number") ? state.volume : 0.6;
    volume.value = audio.volume;

    saveState(false);
  }

  function saveState(playing){
    const payload = {
      index,
      volume: audio.volume,
      playing: !!playing,
      currentTime: audio.currentTime || 0
    };
    localStorage.setItem(LS_KEY, JSON.stringify(payload));
  }

  // 3) UI 交互
  toggleBtn.addEventListener("click", () => {
    panel.classList.toggle("show");
  });
  closeBtn.addEventListener("click", () => panel.classList.remove("show"));

  playBtn.addEventListener("click", async () => {
    try{
      await audio.play();
      saveState(true);
    }catch(e){
      // 浏览器禁止自动播放/或链接跨域不允许等
      alert("播放失败：请确认音乐链接可访问，并在页面上点一下后再播放。");
    }
  });
  pauseBtn.addEventListener("click", () => {
    audio.pause();
    saveState(false);
  });

  nextBtn.addEventListener("click", async () => {
    loadSong(index + 1);
    try{ await audio.play(); saveState(true); }catch(e){ saveState(false); }
  });

  volume.addEventListener("input", () => {
    audio.volume = parseFloat(volume.value);
    saveState(!audio.paused);
  });

  // 进度条
  progress.addEventListener("input", () => {
    if (!audio.duration) return;
    const t = (parseFloat(progress.value) / 100) * audio.duration;
    audio.currentTime = t;
    saveState(!audio.paused);
  });

  audio.addEventListener("timeupdate", () => {
    const cur = audio.currentTime || 0;
    const dur = audio.duration || 0;
    const p = dur ? (cur / dur) * 100 : 0;
    progress.value = String(Math.min(100, Math.max(0, p)));
    timeEl.textContent = `${fmt(cur)} / ${fmt(dur)}`;
  });

  audio.addEventListener("ended", () => {
    loadSong(index + 1);
    // 自动下一首（如果浏览器策略阻止，会静默失败）
    audio.play().then(()=>saveState(true)).catch(()=>saveState(false));
  });

  // 4) 初始化加载
  loadSong(index);

  // 恢复上次播放位置（可选）
  if (typeof state.currentTime === "number") {
    audio.currentTime = Math.max(0, state.currentTime);
  }

  // 恢复“是否在播放”（注意：很多浏览器会阻止无交互自动播放，所以这里做尝试即可）
  if (state.playing) {
    audio.play().then(()=>saveState(true)).catch(()=>saveState(false));
  }
})();
</script>
